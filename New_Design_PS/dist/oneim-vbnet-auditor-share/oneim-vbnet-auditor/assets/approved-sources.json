{
  "policy_version": "2026-03-23",
  "default_oneim_version": "9.3.1",
  "allowed_authorities": [
    {
      "name": "One Identity",
      "domains": [
        "support.oneidentity.com"
      ],
      "priority": 1,
      "use_for": [
        "oneim-behavior",
        "oneim-version-context",
        "oneim-script-guidance"
      ]
    },
    {
      "name": "Microsoft Learn",
      "domains": [
        "learn.microsoft.com"
      ],
      "priority": 2,
      "use_for": [
        "vbnet-semantics",
        "dotnet-analyzers",
        "reliability",
        "performance",
        "api-guidance"
      ]
    },
    {
      "name": "OWASP",
      "domains": [
        "cheatsheetseries.owasp.org",
        "owasp.org"
      ],
      "priority": 3,
      "use_for": [
        "vulnerability-classes",
        "defense-in-depth-guidance"
      ]
    }
  ],
  "blocked_source_types": [
    "blogs",
    "stack-overflow",
    "forums",
    "github-issues",
    "ai-summaries",
    "vendor-marketing"
  ],
  "confidence_rules": {
    "high": [
      "direct-code-evidence",
      "approved-source-match",
      "clear-sink-or-failure-mode",
      "version-matched-oneim-context-when-needed"
    ],
    "medium": [
      "direct-code-evidence",
      "approved-generic-dotnet-or-owasp-guidance",
      "incomplete-oneim-or-runtime-context"
    ],
    "low": [
      "heuristic-smell-without-clear-sink",
      "generalized-owasp-only-pattern",
      "cross-version-oneim-comparison"
    ],
    "fallback": "needs-manual-review"
  },
